# Copy to .env (which is gitignored — never commit it) and fill in.
# Consumed by scripts/set_pipeline_secrets.sh so you don't retype these.

# Anthropic API key used by the Agentic Desk workflows (from console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-...

# Path to the "DPYC Agentic Desk" GitHub App private key (.pem). Optional — you can
# also pass the path as the first script argument. ~ is expanded.
DPYC_BOT_PRIVATE_KEY_FILE=~/Downloads/dpyc-agentic-desk.private-key.pem

# Optional overrides (defaults shown).
# APP_ID=4292331
# OWNER=lonniev
