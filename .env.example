# Copy to .env (which is gitignored — never commit it) and fill in.
# Consumed by scripts/set_pipeline_secrets.sh so you don't retype these.

# Anthropic API key used by the Agentic Desk workflows (from console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-...

# Path to the "DPYC Agentic Desk" GitHub App private key (.pem). Optional — you can
# also pass the path as the first script argument. ~ is expanded.
DPYC_BOT_PRIVATE_KEY_FILE=~/Downloads/dpyc-agentic-desk.private-key.pem

# DPYC Software Factory agent keys — consumed by scripts/bootstrap-factory-secrets.sh.
# ⚠️ nsecs are SECRET. This .env must stay gitignored; treat it as sensitive and shred it
# after provisioning. If an nsec ever lands in a file/log/commit/chat, rotate + republish NIP-05.
PORTER_NSEC=nsec1...        # Service Desk (Porter) key
JOURNEYMAN_NSEC=nsec1...    # Engineering (Journeyman) key

# Optional overrides (defaults shown).
# APP_ID=4292331
# OWNER=lonniev
