{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate preset for DPYC ecosystem repos",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "schedule": ["at any time"],
  "packageRules": [
    {
      "description": "Pin tollbooth-dpyc to exact version; auto-merge patch/minor if CI passes",
      "matchPackageNames": ["tollbooth-dpyc"],
      "matchUpdateTypes": ["patch", "minor"],
      "rangeStrategy": "pin",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Pin tollbooth-dpyc major bumps — require manual review",
      "matchPackageNames": ["tollbooth-dpyc"],
      "matchUpdateTypes": ["major"],
      "rangeStrategy": "pin",
      "automerge": false
    },
    {
      "description": "Auto-merge GitHub Actions minor/patch bumps",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Ignore Python 3.14 — coincurve/cffi not compatible yet",
      "matchPackageNames": ["python"],
      "allowedVersions": "<3.14",
      "enabled": true
    },
    {
      "description": "Group all non-SDK Python dependency bumps into one PR",
      "matchManagers": ["pip_requirements", "pep621"],
      "excludePackageNames": ["tollbooth-dpyc"],
      "groupName": "python dependencies"
    }
  ],
  "pip_requirements": {
    "fileMatch": ["requirements.*\\.txt$"]
  },
  "pep621": {
    "fileMatch": ["pyproject\\.toml$"]
  }
}
